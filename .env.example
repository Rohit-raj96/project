# Local OCR pipeline
# Optional if tesseract.exe is already on PATH.
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Optional for local Windows installs. Leave blank on Linux or Streamlit Cloud so
# poppler-utils is resolved from PATH.
POPPLER_PATH=

# Google Document AI pipeline
DOCUMENT_AI_PROJECT_ID=your-project-id
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=your-processor-id
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
